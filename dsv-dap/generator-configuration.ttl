@prefix : <https://w3id.org/dsv-dap/generator-configuration#>.
@prefix dsvgc: <https://dataspecer.com/work-in-progress/generator-configuration/>.
@prefix ce: <https://dataspecer.com/work-in-progress/generator-configuration/configuration-entry/>.
@prefix kv: <https://dataspecer.com/work-in-progress/generator-configuration/key-value/>.

<https://w3id.org/dsv-dap/generator-configuration#> a dsvgc:configuration;
    dsvgc:has-configurations :json, :data-specification.
:json a <https://dataspecer.com/work-in-progress/generator-configuration/configuration-entry/>;
    dsvgc:has-configuration-type ce:json;
    kv:jsonDefaultTypeKeyMapping "\"technical-label\"";
    kv:jsonIdKeyAlias "\"@id\"";
    kv:jsonTypeKeyAlias "\"@type\"".
:data-specification a <https://dataspecer.com/work-in-progress/generator-configuration/configuration-entry/>;
    dsvgc:has-configuration-type ce:data-specification;
    kv:useGenerators "{\"jsonExample\":false,\"xml\":false,\"csv\":false,\"sparql\":false,\"shacl\":false,\"shex\":false,\"openapi\":false,\"plantUML\":false}".
